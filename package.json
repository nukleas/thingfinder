{
  "name": "thingfinder",
  "version": "0.1.0",
  "description": "CLI tool for searching and downloading 3D printing files across multiple repositories",
  "type": "module",
  "bin": {
    "thingfinder": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "3d-printing",
    "stl",
    "3mf",
    "thingiverse",
    "printables",
    "thangs",
    "cli"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.0",
    "conf": "^13.0.0",
    "impit": "^0.9.2",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
